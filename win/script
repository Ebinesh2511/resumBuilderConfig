param(
    [string]$Base = "https://Ebinesh2511.github.io/resumBuilderConfig"
)

$ErrorActionPreference = "Stop"

$dbName = "resume_builder_v3"
$zipUrl = "$Base/db-zip"
$zipFile = "$dbName.zip"

Write-Host "==> Downloading..."
Invoke-WebRequest $zipUrl -OutFile $zipFile

Write-Host "==> Extracting..."
Expand-Archive $zipFile -DestinationPath . -Force

Write-Host "==> Restoring..."
docker run --rm `
  -v "${PWD}:/restore" `
  --add-host host.docker.internal:host-gateway `
  mongo:latest `
  mongorestore `
    --host host.docker.internal `
    --drop `
    --db $dbName `
    "/restore/$dbName"

Write-Host "==> Cleanup..."
Remove-Item $zipFile -Force
Remove-Item $dbName -Recurse -Force

Write-Host "Done!"
