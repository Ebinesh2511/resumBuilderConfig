param(
    [string]$Base = "https://Ebinesh2511.github.io/resumBuilderConfig"
)

$ErrorActionPreference = "Stop"
$file = "resume_builder_v3.archive"

Write-Host "==> Downloading archive..."
Invoke-WebRequest "$Base/db-archive" -OutFile $file

Write-Host "==> Restoring..."
docker run --rm `
  -v "${PWD}/$file:/tmp/restore.archive" `
  --add-host host.docker.internal:host-gateway `
  mongo:latest `
  mongorestore --host host.docker.internal --drop --archive=/tmp/restore.archive --gzip

Write-Host "==> Cleanup..."
Remove-Item $file -Force

Write-Host "Done!"
