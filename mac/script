#!/bin/bash
set -e

BASE="${1:-https://Ebinesh2511.github.io/resumBuilderConfig}"
FILE="resume_builder_v3.archive"

echo "==> Downloading archive..."
curl -fL "$BASE/db-archive" -o "$FILE"

echo "==> Restoring..."
docker run --rm \
  -v "$(pwd)/$FILE:/tmp/restore.archive" \
  --add-host host.docker.internal:host-gateway \
  mongo:latest \
  mongorestore --host host.docker.internal --drop --archive=/tmp/restore.archive --gzip

echo "==> Cleanup..."
rm -f "$FILE"

echo "Done."
