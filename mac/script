#!/bin/bash
set -e

BASE="${1:-https://Ebinesh2511.github.io/resumBuilderConfig}"

echo "==> Downloading database dump from $BASE/db-zip"
curl -fL "$BASE/db-zip" -o resume_builder_v3.zip

echo "==> Extracting..."
unzip -o resume_builder_v3.zip

echo "==> Restoring to MongoDB..."
mongorestore --drop --db resume_builder_v3 dump/resume_builder_v3

echo "==> Cleanup..."
rm -f resume_builder_v3.zip
rm -rf dump

echo "Done! Database resume_builder_v3 restored."
