#!/bin/bash
set -e

BASE="${1:-https://Ebinesh2511.github.io/resumBuilderConfig}"
DB_NAME="resume_builder_v3"

echo "==> Downloading..."
curl -fL "$BASE/db-zip" -o "$DB_NAME.zip"

echo "==> Extracting..."
unzip -o "$DB_NAME.zip"

echo "==> Restoring..."
docker run --rm \
  -v "$(pwd):/restore" \
  --add-host host.docker.internal:host-gateway \
  mongo:latest \
  mongorestore \
    --host host.docker.internal \
    --drop \
    --db "$DB_NAME" \
    "/restore/$DB_NAME"

echo "==> Cleanup..."
rm -f "$DB_NAME.zip"
rm -rf "$DB_NAME"

echo "Done."
